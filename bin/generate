#!/usr/bin/env ruby
require_relative "../lib/asciidoctor-diagram-layout"

EXAMPLES_DIR = File.join(__dir__, "..", "examples")

EXAMPLES = [
  {
    file:  "single-column",
    title: "Single column layout",
    desc:  "The simplest case: a vertical stack of areas.\n" \
           "Top-level cells without an explicit container are stacked\n" \
           "vertically by default."
  },
  {
    file:  "fixed-size",
    title: "Fixed-size header and footer",
    desc:  "A number in parentheses sets the size as a percentage of the\n" \
           "parent.\n" \
           "The remaining space is distributed equally among auto-sized\n" \
           "cells."
  },
  {
    file:  "sidebar",
    title: "Two-column layout with a sidebar"
  },
  {
    file:  "classic-page",
    title: "Classic page layout",
    desc:  "A header and footer at fixed height, with a sidebar and main\n" \
           "content area in between."
  },
  {
    file:  "dashboard",
    title: "Dashboard with nested sections",
    desc:  "Nesting `rows:` and `cols:` containers produces complex grids."
  }
].freeze

PALETTE_EXAMPLES = %w[warm cool mono pastel].freeze

def read_dsl(name)
  File.read(File.join(EXAMPLES_DIR, "#{name}.dsl"), encoding: "UTF-8")
end

def dsl_attrs(name)
  first = read_dsl(name).lines.first || ""
  return {} unless first.start_with?("#")
  first.scan(/(\w+)=(\S+)/).to_h
end

def dsl_body(name)
  lines = read_dsl(name).lines
  body  = lines.first&.start_with?("#") ? lines.drop(1) : lines
  body.join.rstrip
end

def block_header(name)
  a     = dsl_attrs(name)
  parts = ["layout-rowcol"]
  parts << "width=\"#{a['width']}\""   if a["width"]
  parts << "height=\"#{a['height']}\""  if a["height"]
  parts << "palette=\"#{a['palette']}\"" if a["palette"]
  "[#{parts.join(', ')}]"
end

def generate_svg(name)
  a       = dsl_attrs(name)
  root    = AsciidoctorDiagramLayout::Parser.new.parse(dsl_body(name))
  options = AsciidoctorDiagramLayout::Renderer::RenderOptions.new(
    width:   a.fetch("width",   "400px"),
    height:  a.fetch("height",  "250px"),
    palette: a.fetch("palette", "rainbow")
  )
  svg  = AsciidoctorDiagramLayout::Renderer::SvgRenderer.new.render(root, options)
  path = File.join(EXAMPLES_DIR, "#{name}.svg")
  File.write(path, svg, encoding: "UTF-8")
  puts "Generated examples/#{name}.svg"
end

def generate_readme
  readme = +""

  readme << <<~HEADER
    # asciidoctor-diagram-layout

    An Asciidoctor extension for documenting UI layouts as diagrams.

    ## The problem

    When writing software requirements or design documents, you often need
    to describe the layout of a screen or a page: which areas exist, how
    they are positioned relative to each other, and what proportion of
    space each one occupies.

    The usual alternatives are screenshots, wireframe tools, or hand-drawn
    sketches - none of which live well next to the text, can be diffed in
    version control, or stay in sync as the design evolves.

    This extension lets you describe a layout directly in AsciiDoc source
    using a simple line-oriented DSL.
    The same source serves as both a human-readable description of the
    structure and a machine-rendered visual diagram - there is no separate
    "source" and "picture" to keep in sync.
    The diagram is rendered as HTML (for web output) or SVG (for PDF and
    other backends) without any external tools.

    ## Installation

    Add to your `Gemfile`:

    ```ruby
    gem "asciidoctor-diagram-layout"
    ```

    Or install directly:

    ```
    gem install asciidoctor-diagram-layout
    ```

    ## Usage

    Pass `-r asciidoctor-diagram-layout` to the Asciidoctor CLI:

    ```
    asciidoctor -r asciidoctor-diagram-layout doc.adoc
    ```

    ## Examples

  HEADER

  EXAMPLES.each do |ex|
    readme << "### #{ex[:title]}\n\n"
    readme << "#{ex[:desc]}\n\n" if ex[:desc]
    readme << "```asciidoc\n"
    readme << "#{block_header(ex[:file])}\n"
    readme << "----\n"
    readme << "#{dsl_body(ex[:file])}\n"
    readme << "----\n"
    readme << "```\n\n"
    readme << "![](examples/#{ex[:file]}.svg)\n\n"
  end

  readme << <<~XREF
    ### Referencing document sections

    Cell names support AsciiDoc `xref:` macros.
    The cross-reference is preserved in HTML output and stripped to the
    display label in SVG output.

    ```asciidoc
    [layout-rowcol]
    ----
    cell(10): xref:header[Header]
    cols:
      cell(25): xref:sidebar[Sidebar]
      cell: xref:content[Content]
    cell(10): xref:footer[Footer]
    ----
    ```

    ### Color palettes

    The `palette` attribute controls the color scheme.
    Available values: `rainbow` (default), `warm`, `cool`, `mono`, `pastel`.

  XREF

  PALETTE_EXAMPLES.each do |palette|
    readme << "`#{palette}`:\n\n"
    readme << "![](examples/palette-#{palette}.svg)\n\n"
  end

  readme << <<~FOOTER
    ### PDF output

    When converting to PDF the diagram is written as an SVG file and
    embedded as an image.
    Use the `target` attribute to set the output file name:

    ```asciidoc
    [layout-rowcol, target="page-layout"]
    ----
    cell(10): Header
    cell: Content
    cell(10): Footer
    ----
    ```

    ## DSL syntax

    Each line declares one node.
    Indentation (4 spaces or one tab) defines nesting.

    * `rows:` - container that arranges children vertically
    * `cols:` - container that arranges children horizontally
    * `cell: Name` - leaf cell with a visible label
    * `cell(N): Name` - leaf cell with a fixed size of N% of its parent
    * Containers and cells without an explicit size share the remaining
      space equally
    * Top-level nodes without an explicit container are wrapped in a
      vertical (`rows`) container by default
    * Lines starting with `#` are comments

    ## Block attributes

    * `direction` - implicit direction when no top-level container is
      declared: `rows` (default) or `cols`
    * `renderer` - force output format: `html` or `svg`; defaults to
      `html` for HTML backends and `svg` for all others including PDF
    * `palette` - color scheme: `rainbow` (default), `pastel`, `warm`,
      `cool`, `mono`
    * `width` - diagram width, e.g. `100%` (default) or `800px`
    * `height` - diagram height, e.g. `400px`; not set by default
    * `target` - SVG file name without extension, used when rendering
      to PDF

    ## License

    Apache License 2.0.
    See [LICENSE](LICENSE).
  FOOTER

  path = File.join(__dir__, "..", "README.md")
  File.write(path, readme, encoding: "UTF-8")
  puts "Generated README.md"
end

(EXAMPLES.map { |e| e[:file] } + PALETTE_EXAMPLES.map { |p| "palette-#{p}" }).each do |name|
  generate_svg(name)
end

generate_readme
