#!/usr/bin/env ruby
require_relative "../lib/asciidoctor-diagram-layout"

examples_dir = File.join(__dir__, "..", "examples")

Dir[File.join(examples_dir, "*.dsl")].sort.each do |dsl_file|
  source  = File.read(dsl_file, encoding: "UTF-8")
  lines   = source.lines

  options_line = lines.first&.start_with?("#") ? lines.first : ""
  dsl          = lines.drop(options_line.empty? ? 0 : 1).join

  opts = {}
  options_line.scan(/(\w+)=(\S+)/) { opts[$1] = $2 }

  root    = AsciidoctorDiagramLayout::Parser.new.parse(dsl)
  options = AsciidoctorDiagramLayout::Renderer::RenderOptions.new(
    width:   opts.fetch("width",   "400px"),
    height:  opts.fetch("height",  "250px"),
    palette: opts.fetch("palette", "rainbow")
  )
  svg      = AsciidoctorDiagramLayout::Renderer::SvgRenderer.new.render(root, options)
  svg_file = dsl_file.sub(/\.dsl$/, ".svg")
  File.write(svg_file, svg, encoding: "UTF-8")
  puts "Generated #{File.basename(svg_file)}"
end
